NODE_ENV=development
LOG_LEVEL=info

# --- Redis (shared distributed state) ---
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=rl
REDIS_TIMEOUT_MS=50

# --- Default limit policy ---
# algorithm: token-bucket | sliding-window-log | sliding-window-counter
DEFAULT_ALGORITHM=token-bucket
DEFAULT_WINDOW_MS=60000
DEFAULT_MAX_REQUESTS=100

# --- Optional token-bucket tuning (advanced) ---
# Leave both unset to derive them from the limit above:
#   capacity      = DEFAULT_MAX_REQUESTS
#   refill/sec    = DEFAULT_MAX_REQUESTS / (DEFAULT_WINDOW_MS / 1000)
# Set them only to allow bursts ABOVE the sustained rate. If set,
# DEFAULT_BUCKET_CAPACITY must be >= DEFAULT_MAX_REQUESTS.
# DEFAULT_BUCKET_CAPACITY=150
# DEFAULT_REFILL_RATE_PER_SEC=1.6667

# --- Failure posture when Redis is unreachable ---
# fail-open  = allow traffic (availability-first, default)
# fail-closed = reject traffic (protection-first; use for auth/payment routes)
FAILURE_MODE=fail-open

# --- Ports (must differ) ---
API_PORT=3000
METRICS_PORT=9090