{
  "name": "distributed-rate-limiter",
  "version": "0.1.0",
  "description": "Distributed rate limiter with Redis Lua atomicity — Token Bucket, Sliding Window Log, Sliding Window Counter.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/server.ts",
    "serve": "tsx src/server.ts",
    "start": "node dist/server.js",
    "verify:config": "tsx src/verify-config.ts",
    "verify:limiter": "tsx src/verify-limiter.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}